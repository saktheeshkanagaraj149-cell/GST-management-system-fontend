# ===========================================
# GSTFlow Pro - Environment Variables
# ===========================================
# Copy this file to .env and fill in the values
# DO NOT commit .env to version control

# ── MongoDB Connection ──────────────────────
# Get your connection string from MongoDB Atlas
# Format: mongodb+srv://<username>:<password>@<cluster>/<database>
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/database_name

# ── Authentication ──────────────────────────
# Secret key for signing JWT tokens (use a long random string)
JWT_SECRET=your_super_secret_jwt_key_at_least_32_characters_long

# ── Server Configuration ────────────────────
# Port for local development (Vercel ignores this)
PORT=5000

# ── Client URLs (comma-separated) ─────────
# Add all origins that need to access your API
# Format: http://localhost:port,https://your-domain.com
CLIENT_URLS=http://localhost:5173,http://localhost:3000

# ── Vite Client Variables (prefixed with VITE_) ──
# These are exposed to the frontend

# API URL for the client to connect to
# For Vercel: /api (relative, same origin)
# For local: http://localhost:5000/api
VITE_API_URL=/api

# User's GST-related info (for demo purposes)
VITE_MY_STATE=Tamil Nadu
VITE_MY_GSTIN=33AABCS1234L1ZF